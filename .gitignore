# ─────────────────────────────────────────────
#  CRAG Pipeline — .gitignore
# ─────────────────────────────────────────────

# ── Python ───────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# ── Environment variables ─────────────────────
.env
.env.*
!.env.example

# ── Qdrant persistent vector store ───────────
backend/.qdrant_data/

# ── SQLite history database ───────────────────
backend/data/
*.db
*.sqlite
*.sqlite3

# ── Jupyter Notebooks (checkpoints) ──────────
.ipynb_checkpoints/
*.ipynb

# ── Logs ─────────────────────────────────────
*.log
logs/

# ── OS artifacts ─────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDE / Editor ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── Node / npm ────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ── Vite / Frontend build ────────────────────
frontend/dist/
frontend/.vite/

# ── Testing ───────────────────────────────────
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
coverage.xml
*.test.js.snap

# ── Temporary & misc ──────────────────────────
tmp/
temp/
*.tmp
*.bak
*.orig
